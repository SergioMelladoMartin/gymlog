---
import Layout from '../../layouts/Layout.astro';
import DayHeader from '../../components/DayHeader.astro';
import WorkoutLogger from '../../components/WorkoutLogger';
import {
  getCategories,
  getExercises,
  getSetsForDate,
  getWorkoutComment,
} from '../../lib/queries';

export const prerender = false;

const { date } = Astro.params;
if (!date || !/^\d{4}-\d{2}-\d{2}$/.test(date)) {
  return Astro.redirect('/');
}

const user = Astro.locals.user!;
const [categories, exercises, sets, comment] = await Promise.all([
  getCategories(),
  getExercises(user.id),
  getSetsForDate(user.id, date),
  getWorkoutComment(user.id, date),
]);

const totalVol = sets.reduce((acc, s) => acc + s.weight_kg * s.reps, 0);
const uniqueEx = new Set(sets.map((s) => s.exercise_id)).size;
const hasPr = sets.some((s) => s.pr_weight || s.pr_1rm || s.pr_reps);

const pretty = new Date(date + 'T00:00:00').toLocaleDateString('es-ES', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
});
---
<Layout title={`${pretty} · gymlog`} activeNav="diary">
  <DayHeader
    date={date}
    setCount={sets.length}
    exerciseCount={uniqueEx}
    volume={totalVol}
    hasPr={hasPr}
  />

  <WorkoutLogger
    client:load
    date={date}
    exercises={exercises}
    categories={categories}
    initialSets={sets}
    initialComment={comment}
  />
</Layout>
