---
import Layout from '../../layouts/Layout.astro';
import ExerciseChart from '../../components/ExerciseChart';
import ExerciseHeaderEditor from '../../components/ExerciseHeaderEditor';
import {
  getCategories,
  getExerciseById,
  getExerciseSessionStats,
  getExerciseSetsHistory,
} from '../../lib/queries';

export const prerender = false;

const id = Number(Astro.params.id);
if (!id) return Astro.redirect('/exercises');
const exercise = await getExerciseById(id);
if (!exercise) return Astro.redirect('/exercises');

const [sessions, history, categories] = await Promise.all([
  getExerciseSessionStats(id),
  getExerciseSetsHistory(id, 200),
  getCategories(),
]);

const totalSets = history.length;
const totalSessions = sessions.length;

const best1RM = sessions.reduce((acc, s) => Math.max(acc, s.est_1rm ?? 0), 0);
const heaviest = sessions.reduce((acc, s) => Math.max(acc, s.top_weight ?? 0), 0);

let bestSet = history[0];
for (const s of history) {
  if (!bestSet || s.weight_kg > bestSet.weight_kg || (s.weight_kg === bestSet.weight_kg && s.reps > bestSet.reps)) {
    bestSet = s;
  }
}

const historyByDate = new Map<string, typeof history>();
for (const s of history) {
  if (!historyByDate.has(s.date)) historyByDate.set(s.date, []);
  historyByDate.get(s.date)!.push(s);
}

const formatDate = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
---
<Layout title={`${exercise.name} · gymlog`} activeNav="exercises">
  <div class="mb-5">
    <a href="/exercises" class="mb-2 inline-flex items-center gap-1 text-sm text-muted transition hover:text-fg">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
      Ejercicios
    </a>
    <ExerciseHeaderEditor
      client:load
      exerciseId={exercise.id}
      initialName={exercise.name}
      initialCategoryId={exercise.category_id}
      categoryName={exercise.category_name}
      categoryColor={exercise.category_color}
      categories={categories}
    />
  </div>

  <div class="mb-5 grid grid-cols-2 gap-2 sm:grid-cols-4">
    <div class="stat-tile">
      <div class="section-title">Sesiones</div>
      <div class="mt-0.5 text-2xl font-semibold tabular-nums tracking-tight">{totalSessions}</div>
    </div>
    <div class="stat-tile">
      <div class="section-title">Sets</div>
      <div class="mt-0.5 text-2xl font-semibold tabular-nums tracking-tight">{totalSets}</div>
    </div>
    <div class="stat-tile">
      <div class="section-title">Top peso</div>
      <div class="mt-0.5 text-2xl font-semibold tabular-nums tracking-tight">
        {heaviest}<span class="ml-1 text-sm font-medium text-muted">kg</span>
      </div>
      {bestSet && <div class="text-xs tabular-nums text-muted">{bestSet.weight_kg} × {bestSet.reps}</div>}
    </div>
    <div class="stat-tile relative overflow-hidden">
      <div class="section-title">1RM est.</div>
      <div class="mt-0.5 text-2xl font-semibold tabular-nums tracking-tight text-accent">
        {Math.round(best1RM * 10) / 10}<span class="ml-1 text-sm font-medium text-muted">kg</span>
      </div>
    </div>
  </div>

  <div class="card mb-5 p-4">
    <div class="section-title mb-3">Progresión</div>
    <ExerciseChart client:only="react" data={sessions} />
  </div>

  <div class="card p-4">
    <div class="section-title mb-3">Historial</div>
    <div class="flex flex-col divide-y divide-border">
      {[...historyByDate.entries()].map(([date, sets]) => (
        <a href={`/day/${date}`} class="-mx-2 flex items-baseline justify-between gap-3 rounded-md px-2 py-2.5 text-sm transition hover:bg-elevated">
          <span class="shrink-0 capitalize text-muted">{formatDate(date)}</span>
          <span class="text-right tabular-nums">
            {sets.map((s) => `${s.weight_kg}×${s.reps}`).join(' · ')}
          </span>
        </a>
      ))}
    </div>
  </div>
</Layout>
