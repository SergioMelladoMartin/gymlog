---
import Layout from '../layouts/Layout.astro';
import { db } from '../lib/db';
import { getDayPrCounts } from '../lib/queries';

export const prerender = false;

const url = Astro.url;
const limit = 30;
const before = url.searchParams.get('before'); // fetch days older than this (YYYY-MM-DD)
const after = url.searchParams.get('after');   // fetch days newer than this (YYYY-MM-DD)

// Each page loads `limit` days in reverse-chronological order.
// `before` jumps older, `after` returns to newer pages.
const res = before
  ? await db.execute({
      sql: `SELECT date,
                   COUNT(DISTINCT exercise_id) AS exercise_count,
                   COUNT(*) AS set_count,
                   SUM(weight_kg * reps) AS volume
            FROM training_set
            WHERE date < ?
            GROUP BY date
            ORDER BY date DESC
            LIMIT ?`,
      args: [before, limit],
    })
  : after
  ? await db.execute({
      sql: `SELECT date, exercise_count, set_count, volume FROM (
              SELECT date,
                     COUNT(DISTINCT exercise_id) AS exercise_count,
                     COUNT(*) AS set_count,
                     SUM(weight_kg * reps) AS volume
              FROM training_set
              WHERE date > ?
              GROUP BY date
              ORDER BY date ASC
              LIMIT ?
            ) sub
            ORDER BY date DESC`,
      args: [after, limit],
    })
  : await db.execute({
      sql: `SELECT date,
                   COUNT(DISTINCT exercise_id) AS exercise_count,
                   COUNT(*) AS set_count,
                   SUM(weight_kg * reps) AS volume
            FROM training_set
            GROUP BY date
            ORDER BY date DESC
            LIMIT ?`,
      args: [limit],
    });

const days = res.rows as unknown as Array<{
  date: string;
  exercise_count: number;
  set_count: number;
  volume: number;
}>;

const breakdownRes = days.length
  ? await db.execute({
      sql: `
        SELECT ts.date, e.name AS exercise_name, c.color AS category_color,
               COUNT(*) AS sets, MAX(ts.weight_kg) AS top_weight, MAX(ts.reps) AS top_reps
        FROM training_set ts
        JOIN exercise e ON e.id = ts.exercise_id
        JOIN category c ON c.id = e.category_id
        WHERE ts.date IN (${days.map(() => '?').join(',')})
        GROUP BY ts.date, ts.exercise_id
        ORDER BY ts.date DESC, MIN(ts.id) ASC
      `,
      args: days.map((d) => d.date),
    })
  : { rows: [] as any[] };

const breakdown = new Map<string, Array<{ exercise_name: string; category_color: string | null; sets: number; top_weight: number; top_reps: number }>>();
for (const row of breakdownRes.rows as unknown as Array<{ date: string; exercise_name: string; category_color: string | null; sets: number; top_weight: number; top_reps: number }>) {
  if (!breakdown.has(row.date)) breakdown.set(row.date, []);
  breakdown.get(row.date)!.push(row);
}

const commentsRes = days.length
  ? await db.execute({
      sql: `SELECT date, body FROM workout_comment WHERE date IN (${days.map(() => '?').join(',')})`,
      args: days.map((d) => d.date),
    })
  : { rows: [] as any[] };
const comments = new Map<string, string>();
for (const row of commentsRes.rows as unknown as Array<{ date: string; body: string }>) {
  comments.set(row.date, row.body);
}

const prsByDate = await getDayPrCounts(days.map((d) => d.date));

const formatDate = (iso: string) => {
  const d = new Date(iso + 'T00:00:00');
  return {
    weekday: d.toLocaleDateString('es-ES', { weekday: 'short' }).replace('.', ''),
    day: d.getDate(),
    month: d.toLocaleDateString('es-ES', { month: 'short' }).replace('.', ''),
    year: d.getFullYear(),
  };
};

const oldestDate = days.at(-1)?.date;
const newestDate = days[0]?.date;
const paged = !!(before || after);

// Has-more checks: do any days exist outside the current window?
let hasOlder = false, hasNewer = false;
if (oldestDate) {
  const r = await db.execute({
    sql: 'SELECT EXISTS(SELECT 1 FROM training_set WHERE date < ?) AS has',
    args: [oldestDate],
  });
  hasOlder = !!r.rows[0]?.has;
}
if (newestDate && paged) {
  const r = await db.execute({
    sql: 'SELECT EXISTS(SELECT 1 FROM training_set WHERE date > ?) AS has',
    args: [newestDate],
  });
  hasNewer = !!r.rows[0]?.has;
}
---
<Layout title="Diario · gymlog" activeNav="diary">
  <div class="mb-4 flex items-end justify-between gap-3">
    <div>
      <div class="text-xs font-medium uppercase tracking-wider text-muted">Histórico</div>
      <h1 class="text-3xl font-semibold tracking-tight">Diario</h1>
    </div>
    {paged && (
      <a href="/diary" class="inline-flex shrink-0 items-center gap-1.5 rounded-full border border-border bg-card px-3 py-1.5 text-xs font-medium text-muted transition hover:text-fg" title="Volver al inicio">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17-5-5 5-5" /><path d="m18 17-5-5 5-5" /></svg>
        Inicio
      </a>
    )}
  </div>

  {paged && (hasNewer || oldestDate) && (
    <div class="mb-4 flex items-center justify-between gap-3">
      {hasNewer && newestDate ? (
        <a href={`/diary?after=${newestDate}`} class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-card px-3 py-1.5 text-xs font-medium text-muted transition hover:border-strong hover:text-fg">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
          Más recientes
        </a>
      ) : <span />}

      <span class="text-[11px] text-muted tabular-nums">{days.length} días</span>
    </div>
  )}

  {days.length === 0 ? (
    <p class="text-muted">No hay entrenos registrados todavía.</p>
  ) : (
    <div class="flex flex-col gap-3">
      {days.map((d) => {
        const exs = breakdown.get(d.date) ?? [];
        const note = comments.get(d.date);
        const f = formatDate(d.date);
        const pr = prsByDate.get(d.date);
        const prTotal = (pr?.pr_weight ?? 0) + (pr?.pr_1rm ?? 0) + (pr?.pr_reps ?? 0);
        return (
          <a href={`/day/${d.date}`} class="group card flex overflow-hidden transition hover:border-strong">
            <div class="flex w-20 shrink-0 flex-col items-center justify-center border-r border-border bg-elevated px-3 py-4 text-center">
              <div class="text-[10px] font-semibold uppercase tracking-wider text-muted">{f.weekday}</div>
              <div class="text-3xl font-semibold leading-none tabular-nums tracking-tight">{f.day}</div>
              <div class="mt-1 text-[10px] font-medium uppercase tracking-wider text-muted">{f.month} · {String(f.year).slice(2)}</div>
            </div>
            <div class="min-w-0 flex-1 p-4">
              <div class="flex items-center justify-between gap-2">
                <div class="flex flex-wrap items-center gap-1">
                  {[...new Set(exs.map((e) => e.category_color).filter(Boolean))].slice(0, 4).map((c) => (
                    <span class="h-1.5 w-1.5 rounded-full" style={`background:${c}`} />
                  ))}
                  {prTotal > 0 && (
                    <span class="ml-1 inline-flex items-center gap-1 rounded-md bg-accent px-1.5 py-0.5 text-[10px] font-bold uppercase leading-none tracking-wide text-ink">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M7.5 2h9l1.5 3h3.5l-2.5 5a6 6 0 0 1-4.4 3.85L14 18h2v2H8v-2h2l-.6-4.15A6 6 0 0 1 5 10L2.5 5H6zm0 2-.47.94L8.4 8.67A4 4 0 0 0 12 11a4 4 0 0 0 3.6-2.33L17.47 4.94 17 4z"/></svg>
                      {prTotal}
                    </span>
                  )}
                </div>
                <div class="text-xs tabular-nums text-muted">
                  {d.exercise_count} ej · {d.set_count} sets · {Math.round(d.volume).toLocaleString('es-ES')} kg
                </div>
              </div>
              <ul class="mt-2 flex flex-col gap-1 text-sm">
                {exs.map((e) => (
                  <li class="flex items-center justify-between gap-2">
                    <span class="flex min-w-0 items-center gap-2 truncate">
                      <span class="h-1.5 w-1.5 shrink-0 rounded-full" style={`background:${e.category_color ?? '#888'}`} />
                      <span class="truncate">{e.exercise_name}</span>
                    </span>
                    <span class="shrink-0 tabular-nums text-muted">{e.sets}× · top {e.top_weight}×{e.top_reps}</span>
                  </li>
                ))}
              </ul>
              {note && (
                <p class="mt-3 rounded-md border-l-2 border-accent/70 bg-elevated/40 py-1.5 pl-3 text-xs italic text-subtle">{note}</p>
              )}
            </div>
          </a>
        );
      })}
    </div>
  )}

  <div class="mt-6 flex items-center justify-between gap-3">
    {hasNewer && newestDate ? (
      <a href={`/diary?after=${newestDate}`} class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-card px-4 py-2 text-sm text-muted transition hover:text-fg">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
        Más recientes
      </a>
    ) : paged ? (
      <a href="/diary" class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-card px-4 py-2 text-sm text-muted transition hover:text-fg">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
        Volver al inicio
      </a>
    ) : <span />}

    {hasOlder && oldestDate && (
      <a href={`/diary?before=${oldestDate}`} class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-card px-4 py-2 text-sm text-muted transition hover:text-fg">
        Más antiguos
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
      </a>
    )}
  </div>
</Layout>
