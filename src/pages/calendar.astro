---
import Layout from '../layouts/Layout.astro';
import { getDayPrCounts, getTrainingDaysInRange, todayISO } from '../lib/queries';

export const prerender = false;

const url = Astro.url;
const now = new Date();
const view = (url.searchParams.get('view') ?? 'month') as 'month' | 'year';
const year = Number(url.searchParams.get('year') ?? now.getFullYear());
const month = Number(url.searchParams.get('month') ?? now.getMonth() + 1);
const today = todayISO();

const pad = (n: number) => String(n).padStart(2, '0');

let rangeFrom: string, rangeTo: string;
if (view === 'year') {
  rangeFrom = `${year}-01-01`;
  rangeTo = `${year}-12-31`;
} else {
  const last = new Date(year, month, 0);
  rangeFrom = `${year}-${pad(month)}-01`;
  rangeTo = `${year}-${pad(month)}-${pad(last.getDate())}`;
}

const user = Astro.locals.user!;
const days = await getTrainingDaysInRange(user.id, rangeFrom, rangeTo);
const byDate = new Map(days.map((d) => [d.date, d]));
const prsByDate = await getDayPrCounts(user.id, days.map((d) => d.date));

const totalDays = days.length;
const totalSets = days.reduce((acc, d) => acc + d.set_count, 0);
const totalVolume = days.reduce((acc, d) => acc + d.total_volume, 0);

// ── month view helpers ──
const first = new Date(year, month - 1, 1);
const lastM = new Date(year, month, 0);
const firstWeekday = (first.getDay() + 6) % 7;
const cells: Array<{ iso: string; day: number } | null> = [];
for (let i = 0; i < firstWeekday; i++) cells.push(null);
for (let d = 1; d <= lastM.getDate(); d++) {
  cells.push({ iso: `${year}-${pad(month)}-${pad(d)}`, day: d });
}
while (cells.length % 7 !== 0) cells.push(null);

const prevM = new Date(year, month - 2, 1);
const nextM = new Date(year, month, 1);
const monthName = first.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });

// ── year view helpers ──
// GitHub-style heatmap: columns = weeks, rows = Mon..Sun.
interface HeatCell { iso: string; dow: number; col: number; trained: boolean; sets: number; hasPr: boolean }
const heatCells: HeatCell[] = [];
if (view === 'year') {
  const startOfYear = new Date(year, 0, 1);
  const endOfYear = new Date(year, 11, 31);
  // Align the grid: first column starts on Monday of the week containing Jan 1.
  const firstCol = new Date(startOfYear);
  firstCol.setDate(firstCol.getDate() - ((firstCol.getDay() + 6) % 7));

  let col = 0;
  const cursor = new Date(firstCol);
  while (cursor <= endOfYear) {
    for (let dow = 0; dow < 7; dow++) {
      const inYear = cursor.getFullYear() === year;
      const iso = `${cursor.getFullYear()}-${pad(cursor.getMonth() + 1)}-${pad(cursor.getDate())}`;
      if (inYear) {
        const info = byDate.get(iso);
        const pr = prsByDate.get(iso);
        heatCells.push({
          iso,
          dow,
          col,
          trained: !!info,
          sets: info?.set_count ?? 0,
          hasPr: !!pr && (pr.pr_weight + pr.pr_1rm + pr.pr_reps) > 0,
        });
      }
      cursor.setDate(cursor.getDate() + 1);
    }
    col++;
  }
}
const totalCols = heatCells.length ? Math.max(...heatCells.map((c) => c.col)) + 1 : 0;

// Intensity bucket 0..4 based on set count.
function intensity(sets: number): number {
  if (!sets) return 0;
  if (sets <= 5) return 1;
  if (sets <= 10) return 2;
  if (sets <= 18) return 3;
  return 4;
}

// Month labels for year view: position at the column where each month starts.
const monthLabels = view === 'year' ? Array.from({ length: 12 }, (_, i) => {
  const d = new Date(year, i, 1);
  const col = heatCells.find((c) => c.iso === `${year}-${pad(i + 1)}-01`)?.col ?? 0;
  return { label: d.toLocaleDateString('es-ES', { month: 'short' }).replace('.', ''), col };
}) : [];
---
<Layout title={view === 'year' ? `Año ${year}` : `Calendario · ${monthName}`} activeNav="calendar">
  <div class="mb-4 flex items-center justify-between gap-3">
    {view === 'year' ? (
      <>
        <a href={`/calendar?view=year&year=${year - 1}`} class="grid h-9 w-9 place-items-center rounded-lg border border-border bg-card text-muted transition hover:text-fg" aria-label="Año anterior">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
        </a>
        <h1 class="text-xl font-semibold tracking-tight">{year}</h1>
        <a href={`/calendar?view=year&year=${year + 1}`} class="grid h-9 w-9 place-items-center rounded-lg border border-border bg-card text-muted transition hover:text-fg" aria-label="Año siguiente">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
        </a>
      </>
    ) : (
      <>
        <a href={`/calendar?year=${prevM.getFullYear()}&month=${prevM.getMonth() + 1}`} class="grid h-9 w-9 place-items-center rounded-lg border border-border bg-card text-muted transition hover:text-fg" aria-label="Mes anterior">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
        </a>
        <h1 class="text-xl font-semibold capitalize tracking-tight">{monthName}</h1>
        <a href={`/calendar?year=${nextM.getFullYear()}&month=${nextM.getMonth() + 1}`} class="grid h-9 w-9 place-items-center rounded-lg border border-border bg-card text-muted transition hover:text-fg" aria-label="Mes siguiente">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
        </a>
      </>
    )}
  </div>

  <div class="mb-4 flex items-center justify-center gap-1 rounded-full border border-border bg-card p-1 text-xs font-medium">
    <a
      href={`/calendar?year=${year}&month=${month}`}
      class={`rounded-full px-4 py-1.5 transition ${view === 'month' ? 'bg-accent text-ink' : 'text-muted hover:text-fg'}`}
    >
      Mes
    </a>
    <a
      href={`/calendar?view=year&year=${year}`}
      class={`rounded-full px-4 py-1.5 transition ${view === 'year' ? 'bg-accent text-ink' : 'text-muted hover:text-fg'}`}
    >
      Año
    </a>
  </div>

  <div class="mb-5 grid grid-cols-3 gap-2">
    <div class="stat-tile">
      <div class="section-title">Días</div>
      <div class="mt-0.5 text-2xl font-semibold tabular-nums tracking-tight">{totalDays}</div>
    </div>
    <div class="stat-tile">
      <div class="section-title">Sets</div>
      <div class="mt-0.5 text-2xl font-semibold tabular-nums tracking-tight">{totalSets}</div>
    </div>
    <div class="stat-tile">
      <div class="section-title">Volumen</div>
      <div class="mt-0.5 text-2xl font-semibold tabular-nums tracking-tight">
        {Math.round(totalVolume / 1000)}<span class="ml-0.5 text-sm font-medium text-muted">k</span>
      </div>
    </div>
  </div>

  {view === 'month' ? (
    <>
      <div class="grid grid-cols-7 gap-1.5 text-center text-[11px] font-medium uppercase tracking-wider text-muted">
        {['Lu', 'Ma', 'Mi', 'Ju', 'Vi', 'Sá', 'Do'].map((d) => <div class="py-1">{d}</div>)}
      </div>
      <div class="mt-1 grid grid-cols-7 gap-1.5">
        {cells.map((cell) => {
          if (!cell) return <div class="aspect-square" />;
          const info = byDate.get(cell.iso);
          const isToday = cell.iso === today;
          const colors = info?.categories ? info.categories.split(',').filter(Boolean) : [];
          const trained = !!info;
          const pr = prsByDate.get(cell.iso);
          const hasPr = pr && (pr.pr_weight + pr.pr_1rm + pr.pr_reps) > 0;

          let cellCls = 'group relative flex aspect-square flex-col items-center justify-center rounded-xl text-sm tabular-nums transition ';
          if (trained) {
            cellCls += 'border border-strong bg-card hover:border-accent hover:-translate-y-0.5 hover:shadow-lg ';
          } else {
            cellCls += 'border border-border/40 bg-transparent text-muted hover:border-border hover:bg-card ';
          }
          if (isToday) cellCls += 'ring-2 ring-accent ring-offset-2 ring-offset-bg ';

          return (
            <a href={`/day/${cell.iso}`} class={cellCls}>
              {hasPr && (
                <span class="absolute -top-1 -right-1 grid h-4 w-4 place-items-center rounded-full bg-accent text-ink" title="Récord personal este día">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M7.5 2h9l1.5 3h3.5l-2.5 5a6 6 0 0 1-4.4 3.85L14 18h2v2H8v-2h2l-.6-4.15A6 6 0 0 1 5 10L2.5 5H6zm0 2-.47.94L8.4 8.67A4 4 0 0 0 12 11a4 4 0 0 0 3.6-2.33L17.47 4.94 17 4z"/></svg>
                </span>
              )}
              <span class={`text-base font-semibold ${trained ? 'text-fg' : ''}`}>{cell.day}</span>
              {colors.length > 0 && (
                <div class="mt-1 flex gap-0.5">
                  {colors.slice(0, 4).map((c) => (
                    <span class="h-1.5 w-1.5 rounded-full" style={`background:${c};box-shadow:0 0 0 1px rgba(0,0,0,0.4)`} />
                  ))}
                </div>
              )}
            </a>
          );
        })}
      </div>
    </>
  ) : (
    <div class="card overflow-hidden p-4">
      <div class="mb-2 overflow-x-auto">
        <div class="relative" style={`min-width:${totalCols * 14 + 28}px`}>
          <div class="mb-1 ml-7 h-4 text-[10px] font-medium uppercase tracking-wider text-muted">
            <div class="relative h-full">
              {monthLabels.map((m) => (
                <span class="absolute top-0" style={`left:${m.col * 14}px`}>{m.label}</span>
              ))}
            </div>
          </div>
          <div class="flex gap-1">
            <div class="flex w-5 flex-col justify-between pt-0.5 text-[10px] uppercase text-muted">
              <span>Lu</span>
              <span>Mi</span>
              <span>Vi</span>
              <span>Do</span>
            </div>
            <div class="relative" style={`width:${totalCols * 14}px;height:${7 * 14}px`}>
              {heatCells.map((hc) => {
                const level = intensity(hc.sets);
                const isToday = hc.iso === today;
                const title = hc.trained
                  ? `${hc.iso} — ${hc.sets} sets${hc.hasPr ? ' · PR' : ''}`
                  : `${hc.iso} — sin entreno`;
                const bg =
                  level === 0 ? 'color-mix(in srgb, var(--color-border) 40%, transparent)'
                  : level === 1 ? 'color-mix(in srgb, var(--color-accent) 25%, var(--color-card))'
                  : level === 2 ? 'color-mix(in srgb, var(--color-accent) 50%, var(--color-card))'
                  : level === 3 ? 'color-mix(in srgb, var(--color-accent) 75%, var(--color-card))'
                  :                'var(--color-accent)';
                return (
                  <a
                    href={`/day/${hc.iso}`}
                    title={title}
                    class={`absolute rounded-sm transition hover:scale-125 ${isToday ? 'ring-1 ring-fg' : ''}`}
                    style={`left:${hc.col * 14}px;top:${hc.dow * 14}px;width:11px;height:11px;background:${bg}`}
                  >
                    {hc.hasPr && <span class="absolute -top-0.5 -right-0.5 h-1.5 w-1.5 rounded-full bg-accent ring-1 ring-bg" />}
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      </div>

      <div class="mt-4 flex items-center justify-end gap-2 text-[11px] text-muted">
        <span>menos</span>
        {[0, 1, 2, 3, 4].map((lvl) => {
          const bg =
            lvl === 0 ? 'color-mix(in srgb, var(--color-border) 40%, transparent)'
            : lvl === 1 ? 'color-mix(in srgb, var(--color-accent) 25%, var(--color-card))'
            : lvl === 2 ? 'color-mix(in srgb, var(--color-accent) 50%, var(--color-card))'
            : lvl === 3 ? 'color-mix(in srgb, var(--color-accent) 75%, var(--color-card))'
            :              'var(--color-accent)';
          return <span class="inline-block h-2.5 w-2.5 rounded-sm" style={`background:${bg}`} />;
        })}
        <span>más</span>
      </div>
    </div>
  )}
</Layout>
