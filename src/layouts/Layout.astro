---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SideNav from '../components/SideNav';
import SyncStatus from '../components/SyncStatus';
import Onboarding from '../components/Onboarding';

interface Props {
  title?: string;
  activeNav?: 'today' | 'calendar' | 'diary' | 'stats' | 'exercises' | 'login';
}

const { title = 'gymlog', activeNav = 'today' } = Astro.props;

const navTitle = {
  today: 'Hoy',
  calendar: 'Calendario',
  diary: 'Diario',
  exercises: 'Ejercicios',
  stats: 'Estadísticas',
  login: 'Acceso',
}[activeNav];
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0b0b0f" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline data-astro-rerun>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var sysDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.setAttribute('data-theme', stored || (sysDark ? 'dark' : 'light'));
          var accent = localStorage.getItem('accent');
          if (accent && accent !== 'lime') document.documentElement.setAttribute('data-accent', accent);
          // Apply the persisted "collapsed sidebar" preference before paint.
          var collapsed = localStorage.getItem('sidenav-collapsed') === '1';
          if (collapsed) document.body && document.body.classList.add('sidenav-collapsed');
          // body may not exist yet during <head>; the class is also applied
          // inline below as a fallback through the data attribute.
          window.__gymlogSidenavCollapsed = collapsed;
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').catch(function () {});
        });
      }
    </script>
  </head>
  <body class="min-h-dvh" data-sidenav={activeNav !== 'login' ? '' : undefined}>
    <script is:inline>
      // Apply the collapsed-sidebar class on body (the head script ran before
      // body existed). Idempotent across Astro client-side navigations.
      try {
        if (window.__gymlogSidenavCollapsed) document.body.classList.add('sidenav-collapsed');
        else document.body.classList.remove('sidenav-collapsed');
      } catch (e) {}
    </script>
    <header class="sticky top-0 z-30 border-b border-border/70 backdrop-blur-xl" style="background: color-mix(in srgb, var(--color-bg) 75%, transparent);">
      <div class="mx-auto flex max-w-3xl items-center gap-3 px-4 py-3">
        {activeNav !== 'login' && <SideNav client:load transition:persist="sidenav" active={activeNav} />}
        <div class="flex min-w-0 flex-1 items-center gap-2">
          <a href="/" class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-accent text-ink" aria-label="Ir a Hoy">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.4 14.4 9.6 9.6" />
              <path d="M18.657 21.485a2 2 0 1 1-2.829-2.828l-1.767 1.768a2 2 0 1 1-2.829-2.829l6.364-6.364a2 2 0 1 1 2.829 2.829l-1.768 1.767a2 2 0 1 1 2.828 2.829z" />
              <path d="m21.5 21.5-1.4-1.4" />
              <path d="M3.9 3.9 2.5 2.5" />
              <path d="M6.404 12.768a2 2 0 1 1-2.829-2.829l1.768-1.767a2 2 0 1 1-2.828-2.829l2.828-2.828a2 2 0 1 1 2.829 2.828l1.767-1.768a2 2 0 1 1 2.829 2.829z" />
            </svg>
          </a>
          <span class="truncate text-[15px] font-semibold tracking-tight">{navTitle}</span>
        </div>
        {activeNav !== 'login' && <SyncStatus client:only="react" transition:persist="sync-status" />}
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-6">
      <slot />
    </main>
    {activeNav !== 'login' && <Onboarding client:only="react" />}
  </body>
</html>
